# CLRTY PRISM — copy to .env at repo root (never commit .env)
# Gate env is auto-synced to apps/prism-cli/.env on terminal launch/build.

# ── Blockchain API (live mode) ─────────────────────────────────
CLRTY_API_URL=http://127.0.0.1:8545
# CLRTY_API_KEY=

# ── Terminal access gate (operator — keep secret) ──────────────
# Single master for personal access codes: clrt gate password
CLRTY_GATE_MASTER=

# Operator admin override (separate from personal codes)
CLRTY_PRISM_ADMIN_PASS=

# Set to 1 to disable gate at public launch
# VITE_PRISM_TERMINAL_PUBLIC=0

# ── Dev API helpers ────────────────────────────────────────────
# CLRTY_DEV_PARTNER_APPROVED=1
